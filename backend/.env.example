# LLM API config. Compatible with OpenAI-style endpoints.
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Local SQLite database used by the current runnable CatTrace backend.
