# ============================================================
# VisAgent - 环境变量配置模板
# 复制此文件为 .env 并填写实际值
# ============================================================

# ── 应用基础配置 ──────────────────────────────────
APP_NAME=VisAgent
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

# ── 数据库配置（与 docker-compose.yml 对应）───────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=visagent
DB_USER=visagent
DB_PASSWORD=visagent

# ── Redis 配置 ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── MinIO 配置 ────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=visagent-images
MINIO_SECURE=false

# ── JWT 认证配置 ──────────────────────────────────
JWT_SECRET_KEY=visagent-dev-secret-key-2026
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── 大模型配置（OpenAI 兼容接口）────────────────
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ── LangChain 配置（可选）───────────────────────
# 启用 LangSmith 监控（可选，不需要可设为 false）
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=visagent

# ── CORS 配置 ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
