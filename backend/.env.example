# Backend service config.
HOST=0.0.0.0
PORT=8888
DEBUG=false
SQL_ECHO=false

# Frontend dev origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
